{
  "name": "unreadable-typescript",
  "version": "1.4.0",
  "type": "module",
  "private": false,
  "description": "type UnreadableType<T> = T extends object ? { [K in keyof T]: UnreadableType<T[K]> } : T;",
  "repository": {
    "type": "git",
    "url": "https://github.com/arthur-plazanet/unreadable-typescript"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "!**/*.map"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./enum": "./dist/enum/index.js",
    "./interface": "./dist/interface/index.js",
    "./type": "./dist/type/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "typescript",
    "type",
    "utility",
    "unreadable"
  ],
  "author": "Arthur Plazanet",
  "license": "ISC",
  "devDependencies": {
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.1.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
