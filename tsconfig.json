{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "lib": ["ESNext"],
    "declaration": true,
    "rootDir": "src",
    "allowJs": true,
    "outDir": "./build",
    "noEmit": false,
    "esModuleInterop": true,
    "noImplicitAny": false,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": [],
  "ts-node": {
    "require": ["tsconfig-paths/register"]
  }
}
